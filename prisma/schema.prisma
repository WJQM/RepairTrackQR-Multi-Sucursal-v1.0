generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  address   String?
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  repairs   Repair[]
  services      Service[]
  inventoryItems InventoryItem[]
  software      Software[]
  quotations    Quotation[]
  notifications Notification[]
  messages      Message[]
  certificates  Certificate[]
  equipment     Equipment[]
  videogames    Videogame[]
  consoles      Console[]
}

model User {
  id              String         @id @default(uuid())
  name            String
  email           String         @unique
  password        String
  role            String         @default("admin")
  status          String         @default("active")
  phone           String?
  image           String?
  branchId        String?
  createdAt       DateTime       @default(now())
  branch          Branch?        @relation(fields: [branchId], references: [id])
  notifications   Notification[]
  assignedRepairs Repair[]       @relation("AssignedRepairs")
  repairs         Repair[]       @relation("CreatedRepairs")
  quotations      Quotation[]
  messages        Message[]
  certificates    Certificate[]
}

model Repair {
  id            String    @id @default(uuid())
  code          String
  device        String
  issue         String
  status        String    @default("pending")
  priority      String    @default("media")
  estimatedCost Float     @default(0)
  notes         String?
  qrCode        String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  userId        String
  branchId      String
  image         String?
  brand         String?
  clientEmail   String?
  clientName    String?
  clientPhone   String?
  model         String?
  accessories   String?
  technicianId  String?
  technician    User?     @relation("AssignedRepairs", fields: [technicianId], references: [id])
  user          User      @relation("CreatedRepairs", fields: [userId], references: [id])
  branch        Branch    @relation(fields: [branchId], references: [id])
  messages      Message[]

  @@unique([code, branchId])
  @@unique([qrCode, branchId])
  @@index([branchId, status])
  @@index([branchId, createdAt])
  @@index([technicianId])
  @@index([clientName])
}

model Notification {
  id        String   @id @default(uuid())
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  branchId  String
  user      User     @relation(fields: [userId], references: [id])
  branch    Branch   @relation(fields: [branchId], references: [id])

  @@index([userId, read])
  @@index([branchId, createdAt])
}

model Service {
  id        String   @id @default(cuid())
  name      String
  price     Float
  icon      String   @default("🔧")
  active    Boolean  @default(true)
  branchId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branch    Branch   @relation(fields: [branchId], references: [id])

  @@index([branchId])
}

model InventoryItem {
  id        String       @id @default(cuid())
  name      String
  category  String?
  quantity  Int          @default(0)
  price     Float        @default(0)
  minStock  Int          @default(5)
  active    Boolean      @default(true)
  branchId  String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  image     String?
  serials   SerialUnit[]
  branch    Branch       @relation(fields: [branchId], references: [id])

  @@index([branchId])
}

model SerialUnit {
  id              String        @id @default(cuid())
  serialNumber    String        @unique
  status          String        @default("available")
  inventoryItemId String
  soldTo          String?
  soldAt          DateTime?
  repairCode      String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  item            InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
}

model Software {
  id              String   @id @default(cuid())
  name            String
  category        String?
  image           String?
  active          Boolean  @default(true)
  branchId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  minRequirements String?
  recRequirements String?
  size            String?
  description     String?
  language        String?
  rating          String?
  branch          Branch   @relation(fields: [branchId], references: [id])

  @@index([branchId])
}

model Quotation {
  id          String   @id @default(cuid())
  code        String
  type        String   @default("quotation")
  clientName  String
  clientPhone String?
  items       String
  total       Float    @default(0)
  notes       String?
  branchId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  branch      Branch   @relation(fields: [branchId], references: [id])

  @@unique([code, branchId])
  @@index([branchId, type, createdAt])
}

model Message {
  id        String   @id @default(uuid())
  text      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  repairId  String
  userId    String
  branchId  String
  repair    Repair   @relation(fields: [repairId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  branch    Branch   @relation(fields: [branchId], references: [id])

  @@index([repairId])
  @@index([branchId])
}

model Certificate {
  id             String   @id @default(cuid())
  code           String
  clientName     String
  computerName   String?
  windowsEdition String?
  windowsSerial  String?
  officeEdition  String?
  officeSerial   String?
  date           String
  technician     String
  notes          String?
  branchId       String
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  branch         Branch   @relation(fields: [branchId], references: [id])
  user           User     @relation(fields: [userId], references: [id])

  @@unique([code, branchId])
  @@index([branchId, createdAt])
}

model Equipment {
  id            String   @id @default(cuid())
  code          String   @default("")
  name          String
  type          String   @default("laptop") // laptop | desktop
  brand         String?
  model         String?
  processor     String?
  ram           String?
  storage       String?
  storage2      String?
  screenSize    String?
  graphicsCard  String?
  os            String?
  cabinet       String?
  powerSupply   String?
  motherboard   String?
  accessories   String?
  condition     String   @default("disponible") // disponible | vendido | en_reparacion
  price         Float    @default(0)
  notes         String?
  image         String?
  branchId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  branch        Branch   @relation(fields: [branchId], references: [id])

  @@unique([code, branchId])
  @@index([branchId])
  @@index([branchId, type])
}

model Settings {
  id          String   @id @default("global")
  companyName String   @default("RepairTrackQR")
  slogan      String   @default("Servicio Técnico Especializado")
  logo        String?
  phone       String?
  email       String?
  address     String?
  website     String?
  updatedAt   DateTime @updatedAt
}

model Videogame {
  id              String   @id @default(cuid())
  name            String
  platform        String?  // PC, Nintendo Switch, Nintendo Wii, PSP, PS Vita... (ampliable)
  genre           String?  // Acción, RPG, Deportes, etc.
  description     String?
  size            String?  // "50 GB", "1.2 GB"
  minRequirements String?  // Solo aplica a PC — opcional
  recRequirements String?
  language        String?  // Español, Inglés, Multi, etc.
  rating          String?  // PEGI-18, ESRB-M, PEGI-7, etc.
  image           String?  // JSON array de URLs o URL única
  active          Boolean  @default(true)
  branchId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  branch          Branch   @relation(fields: [branchId], references: [id])

  @@index([branchId])
  @@index([branchId, platform])
}

model Console {
  id            String   @id @default(cuid())
  code          String   @default("")
  name          String
  category      String?  // Nintendo, Sony, Microsoft... (ampliable)
  state         String?  // "nueva" | "usada"
  brand         String?
  model         String?
  color         String?
  storage       String?
  generation    String?
  accessories   String?
  condition     String   @default("disponible") // disponible | vendida | reservada
  price         Float    @default(0)
  notes         String?
  image         String?
  active        Boolean  @default(true)
  branchId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  branch        Branch   @relation(fields: [branchId], references: [id])

  @@unique([code, branchId])
  @@index([branchId])
  @@index([branchId, category])
  @@index([branchId, condition])
}

// Registro de visitas al portal público
model PageView {
  id           String   @id @default(cuid())
  path         String   // "/portal", "/track/OT-5", "/certificate-view/CE-3"
  documentType String?  // "ot" | "ce" | "cot" | "nv" | "eq" | "cn" | "cl" | null
  documentCode String?  // "OT-5", "CE-3", null si es portal principal
  ipHash       String?  // SHA-256 de IP (para uniqueness sin PII)
  userAgent    String?  // Browser info (truncado a 300 chars)
  referrer     String?  // URL de donde vino
  branchId     String?  // Si se pudo asociar a una sucursal
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([documentType, createdAt])
  @@index([documentCode])
  @@index([path, createdAt])
}

// Historial de cambios de estado de OTs
model StatusHistory {
  id          String   @id @default(cuid())
  repairId    String
  fromStatus  String?  // null si es el estado inicial
  toStatus    String
  changedBy   String?  // userId que hizo el cambio
  changedByName String? // nombre del usuario (cacheado)
  notes       String?  // comentario opcional
  createdAt   DateTime @default(now())

  @@index([repairId, createdAt])
}

// Caja chica: movimientos de dinero (ingresos y egresos)
model CashMovement {
  id          String   @id @default(cuid())
  type        String   // "income" | "expense"
  category    String   // "repuestos" | "servicios" | "pagos" | "ventas" | "otros" | "ajuste"
  amount      Float
  description String
  notes       String?
  createdBy   String?  // userId
  createdByName String? // nombre usuario cacheado
  branchId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([branchId, createdAt])
  @@index([branchId, type, createdAt])
}

// Reseñas/calificaciones del cliente al entregar OT
model Review {
  id          String   @id @default(cuid())
  repairId    String   @unique
  repairCode  String   // OT-X
  rating      Int      // 1-5 estrellas
  comment     String?
  clientName  String?
  branchId    String
  createdAt   DateTime @default(now())

  @@index([branchId, createdAt])
  @@index([rating])
}
